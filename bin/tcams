#!/usr/bin/bash

#Script to stream wyze cams via MPV using rtsp protocol
#exec 2>>/home/brandon/Public/rtsp.log
#Setup some variables

cams=("backyard" "driveway" "both")

PS3="Which camera would you like to view? "

my_choice=${my_choice}

#Provide multiple choice selection option to terminal user
select pick in "${cams[@]}"; do
   my_choice="${pick}"
   [[ -n "$my_choice" ]] && break
done < /dev/tty

#Echo user selection to stdout
echo "You chose $my_choice"

#Test user selection against known cameras and stream correct view
if
 [ "$my_choice" = "driveway" ]; then
  exec /usr/bin/mpv --no-audio 'rtsp://admin:adminadmin@192.168.1.42/live' >>$HOME/Public/rtsp.log 2>&1 &
  elif
 [ "$my_choice" = "backyard" ]; then
  exec /usr/bin/ffplay -an -noborder -infbuf -framedrop 'rtsp://admin:adminadmin@192.168.1.41/live' &>/dev/null &
  elif
 [ "$my_choice" = "both" ]; then
  exec /usr/bin/mpv --no-audio 'rtsp://admin:adminadmin@192.168.1.42/live' >>$HOME/Public/rtsp.log 2>&1 &
  exec /usr/bin/mpv --no-audio 'rtsp://admin:adminadmin@192.168.1.41/live' >>$HOME/Public/rtsp.log 2>&1 &
  else
  echo "ERROR";
fi
    exec /usr/bin/ffplay -an -alwaysontop -noborder -infbuf -framedrop -x 970 -y 523 -top 0 -left 951 'rtsp://admin:adminadmin@192.168.1.41/live' &>/dev/null &
