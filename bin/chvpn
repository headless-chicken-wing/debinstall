#!/usr/bin/bash

set -eu

YW=$(echo "\033[33m")
BL=$(echo "\033[36m")
RD=$(echo "\033[01;31m")
BGN=$(echo "\033[4;92m")
GN=$(echo "\033[1;92m")
DGN=$(echo "\033[32m")
CL=$(echo "\033[m")
CM="${GN}✓${CL}"
CROSS="${RD}✗${CL}"
BFR="\\r\\033[K"
HOLD=" "

# This function displays an informational message with a yellow color.
msg_info() {
  local msg="$1"
  echo -e "${YW}${msg}${CL}"
}

# This function displays a success message with a green color.
msg_ok() {
  declare -g msg="$1"
  echo -e "${BFR} ${CM} ${GN}${msg}${CL}"
}

# This function displays a error message with a red color.
msg_error() {
  local msg="$1"
  echo -e "${BFR} ${CROSS} ${RD}${msg}${CL}"
}

qbitip=$(ssh -t debian docker exec qbittorrent curl -sS https://ifconfig.me || echo "someting wrong")
wanip=$(ssh -t debian curl -sS https://ifconfig.me || echo "someting very wrong")
myip=$(curl -sS ifconfig.me || echo "someting very very wrong")

msg_info "Qbit's host WAN ip address is: ${wanip}"
echo -e " "
msg_info "Qbittorrent's ip address is ${qbitip}"
echo -e " "
msg_info "This computer's public ip address is ${myip}"
echo -e " "


if
 [ $wanip != $qbitip ]; then
  msg_ok "QBITTORRENT'S VPN IS ACTIVE!"
 elif
  [ $wanip = $qbitip ]; then
  msg_error "WARNING!!!"
  msg_error "QBITTORRENT'S VPN IS NOT RUNNING!"
  echo -e " "
 else
  msg_error "something is fucked!!!"
  echo -e "\n"
fi
