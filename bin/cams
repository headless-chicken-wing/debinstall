#!/usr/bin/env bash

                    ###Script to stream wyze cams via MPV using rtsp protocol###

#Setup some variables
YW=$(echo "\033[33m")
BL=$(echo "\033[36m")
RD=$(echo "\033[01;31m")
BGN=$(echo "\033[4;92m")
GN=$(echo "\033[1;92m")
DGN=$(echo "\033[32m")
CL=$(echo "\033[m")
CM="${GN}✓${CL}"
CROSS="${RD}✗${CL}"
BFR="\\r\\033[K"
HOLD=" "

# This function displays an informational message with a yellow color.
msg_info() {
  local msg="$1"
  echo -e "${YW}${msg}${CL}"
}

# This function displays a success message with a green color.
msg_ok() {
  local msg="$1"
  echo -e "${BFR} ${CM} ${GN}${msg}${CL}"
}

# This function displays a error message with a red color.
msg_error() {
  local msg="$1"
  echo -e "${BFR} ${CROSS} ${RD}${msg}${CL}"
}

cams=('backyard' 'driveway' 'portable-cam' 'all')

#echo $cams

#Provide multiple choice selection option to terminal user
msg_info "What camera would you like to view? "
PS3="Select number and press enter: "

select pick in "${cams[@]}"; do
 case $pick in
  backyard)
    exec /usr/bin/ffplay  -x 1200 -y 800 -alwaysontop -noborder -infbuf -framedrop 'rtsp://admin:adminadmin@192.168.1.41/live' &>/dev/null &
    ;;

  driveway)
#    exec /usr/bin/ffplay -an -alwaysontop -noborder -infbuf -exitonkeydown -framedrop -x 950 -y 545
#    'rtsp://admin:adminadmin@192.168.1.42/live' &>/dev/null &
    exec /usr/bin/ffplay -an -alwaysontop -noborder -infbuf -framedrop -x 1300 -y 700  'rtsp://admin:adminadmin@192.168.1.42/live' &>/dev/null &
    ;;

  portable)
    exec /usr/bin/ffplay -noborder -fs 'rtsp://admin:adminadmin@192.168.1.40/live' &>/dev/null &
    ;;

  all)
    exec /usr/bin/ffplay -an -alwaysontop -noborder -infbuf -framedrop -x 970 -y 523 -top 0 -left 951 'rtsp://admin:adminadmin@192.168.1.41/live' &>/dev/null &
    exec /usr/bin/ffplay -an -alwaysontop -noborder -infbuf -framedrop -x 970 -y 523 -top 0 -left 0 'rtsp://admin:adminadmin@192.168.1.42/live' &>/dev/null &
    exec /usr/bin/ffplay -an -alwaysontop -noborder -infbuf -framedrop -x 970 -y 523 -top 559 -left 0 'rtsp://admin:adminadmin@192.168.1.40/live' &>/dev/null &
    ;;

  *)
    echo -e "Error!"
    ~/.local/bin/ccams
    ;;
  esac
break
done

msg_ok "Now streaming "${pick}" on "${DISPLAY}""

sleep 5
exit 0

