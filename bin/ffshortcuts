#!/usr/bin/bash
# This function sets various color variables using ANSI escape codes for formatting text in the terminal.
YW=$(echo "\033[33m")
BL=$(echo "\033[36m")
RD=$(echo "\033[01;31m")
BGN=$(echo "\033[4;92m")
GN=$(echo "\033[1;92m")
DGN=$(echo "\033[32m")
CL=$(echo "\033[m")
CM="${GN}✓${CL}"
CROSS="${RD}✗${CL}"
BFR="\\r\\033[K"
HOLD=" "



# This function displays an informational message with a yellow color.
msg_info() {
  local msg="$1"
  echo -e "${YW}${msg}${CL}"
}

# This function displays a success message with a green color.
msg_ok() {
  declare -g msg="$1"
  echo -e "${BFR} ${CM} ${GN}${msg}${CL}"
}

# This function displays a error message with a red color.
msg_error() {
  local msg="$1"
  echo -e "${BFR} ${CROSS} ${RD}${msg}${CL}"
}




Navigation()
{
    /usr/bin/bat -p -P -l perl <<EOF
	Command 	Shortcut
	Back 		Alt + ←
	Forward 	Alt + →
	Home	 	Alt + Home
	Open File 	Ctrl + O
	Reload 		Ctrl + R
	Reload(nocache) Ctrl + Shift + R
	Stop	 	Esc
EOF
}



Windows-and-Tabs()
{
    /usr/bin/bat -p -P -l perl <<EOF
	Close Tab 	Ctrl + W
	Close Window 	Ctrl + Shift + W
	Cycle Tabs 	Ctrl + Tab
	Quit 	 	Ctrl + Q
	Tab to Left	Ctrl + Page Up
	Tab to Right    Ctrl + Page Down
	Move Tab Left 	Ctrl + Shift + Page Up
	Move Tab Right 	Ctrl + Shift + Page Down
	Tab to start 	Ctrl + Shift + Home
	Tab to end 	Ctrl + Shift + End
	Mute Audio 	Ctrl + M
	New Tab 	Ctrl + T
	New Window 	Ctrl + N
	Private Window 	Ctrl + Shift + P
	Open last  tab 	Ctrl + Shift + T
	Move URL 	Ctrl + Shift + X
EOF
}

Browser-Tools()
{
	/usr/bin/bat -p -P -l perl <<EOF
	Downloads 	Ctrl + Shift + Y
	Add-ons 	Ctrl + Shift + A
	Dev Tools 	Ctrl + Shift + I
	Web Console 	Ctrl + Shift + K
	Inspector 	Ctrl + Shift + C
	Screenshot 	Ctrl + Shift + S
	Style Editor 	Shift + F7
	Task Manager 	Shift + Esc
	Profiler 	Shift + F5
	Network 	Ctrl + Shift + E
	Edit CSS 	Ctrl + Shift + M
	Page Source 	Ctrl + U
	Console 	Ctrl + Shift + J
	Page Info 	Ctrl + I
EOF
}

