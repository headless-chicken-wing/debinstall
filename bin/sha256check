#!/usr/bin/bash

#alpinesha=(cat /home/brandon/Downloads/alpine-extended-3.21.0-x86_64.iso.sha256 | cut --delimiter=  --fields=1)

echo -n "Enter the shasum you were given at time of download: "
read provided

iso=$(ls -AF --sort=time "$HOME"/Downloads/*.iso | head -n 1 )
expected=$provided

echo "Hello "$USER"..."
echo " "
echo "Using "$expected" as shasum "
#echo " "
echo "for comparrison against "$iso" "
echo " "
echo "Calculating and Comparing..."
echo " "

calculated=$(/usr/bin/sha256sum $iso | cut --delimiter=" " --fields=1)

if
  [ "$calculated" = "$expected" ]; then
  echo "Congrats, they fucking match!"; elif
  [ "$calculated" != "$expected" ]; then
  echo "Hey FAGGOT" "WARNING! shasums DO NOT match!!!"; else
  echo "Error Dumbass System Error" && echo "You fucked it up...exiting";
fi

echo " "
echo "Checked file: "" ""$iso"
echo " "
echo "Compare: ""$expected"
echo "Against: ""$calculated"

#if [ (shasum /home/brandon/Downloads/pop-os_22.04_amd64_intel_49.iso | cut --delimiter=  --fields=1) == 1f6288352e7e8c65e55b29490a8d9da23669947c307429137f0549c6365c6cc5 ]; then echo
#Good to Go; else echo ERROR; fi
